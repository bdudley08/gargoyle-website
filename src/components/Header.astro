---
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const links = [
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
];
---

<header class="site-header">
  <div class="container">
    <a href="/" class="brand" aria-label="Gargoyle Exterior Cleaning — home">
      <span class="brand-mark" aria-hidden="true"></span>
      GARGOYLE
    </a>
    <nav class="site-nav" aria-label="Main">
      {links.map((link) => (
        <a href={link.href} aria-current={path === link.href ? 'page' : undefined}>
          {link.label}
        </a>
      ))}
      <a
        href="/contact"
        class="nav-cta"
        aria-current={path === '/contact' ? 'page' : undefined}
      >
        Get a quote
      </a>
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle light and dark theme">
        <svg class="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
        </svg>
        <svg class="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4m11.4-11.4 1.4-1.4" />
        </svg>
      </button>
    </nav>
  </div>
</header>

<script is:inline>
  document.getElementById('theme-toggle').addEventListener('click', () => {
    const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>
