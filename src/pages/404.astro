---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page Not Found — Gargoyle Exterior Cleaning"
  description="That page doesn't exist. Head back to Gargoyle Exterior Cleaning's home page."
>
  <section class="section section--flush" style="padding-block: clamp(5rem, 14vw, 10rem);">
    <div class="container">
      <p class="kicker">404</p>
      <h1 class="display">Nothing up here.</h1>
      <p class="lede">
        This page doesn't exist — unlike the debris in your gutters, which
        definitely does.
      </p>
      <div class="btn-row">
        <a href="/" class="btn">Back to home</a>
        <a href="/contact" class="btn btn--ghost">Get a quote</a>
      </div>
    </div>
  </section>
</Base>
